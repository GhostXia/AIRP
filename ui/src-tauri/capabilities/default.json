{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AIRP UI default capabilities. Minimal permission surface (守不变式3).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/airp-core", "sidecar": true }
      ]
    }
  ]
}
