AIRP_VERSION=0.1.0
AIRP_DATA_VOLUME=airp-data
AIRP_PUBLIC_ORIGIN=https://airp.example.com
AIRP_TLS_MODE=public
AIRP_ADMIN_USER=airp-admin
AIRP_ENDPOINT=https://api.openai.com/v1/chat/completions
AIRP_MODEL=gpt-4o
AIRP_LOG=info
AIRP_HTTP_PORT=80
AIRP_HTTPS_PORT=443
# files mode only; paths are inside the gateway container.
AIRP_TLS_CERT_DIR=./certs
AIRP_TLS_CERT_FILE=/run/airp-tls/fullchain.pem
AIRP_TLS_KEY_FILE=/run/airp-tls/privkey.pem
