# Rust
/target/
/dist/
**/*.rs.bk
*.pdb

# 防御：忽略 rustup/cargo 误生成在 worktree 内的本机元数据目录
.rustup/
.cargo/

# Cargo workspace — 各成员不再保留独立 lock/target
crates/*/target/
crates/*/Cargo.lock
ui/src-tauri/target/
ui/src-tauri/Cargo.lock

# Node / 前端
ui/node_modules/
ui/dist/
ui/dist-ssr/
ui/.vite/
*.local

# Tauri
ui/src-tauri/gen/schemas/
ui/src-tauri/binaries/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 环境与密钥
.env
.env.local
.env.*.local

# 运行时数据（core 的样本数据保留入库，但运行产物忽略）
# 引擎运行时产物（Phase 0 端到端验证生成）：config.json 是 daemon 启动自动写的，
# history/ turn_counter/ quota.json 是会话/封卷/quota 计数器，均不入库。
config.json
data/quota.json

# 个人 RP 数据不入库（角色卡/预设含个人内容，历史泄露已用 filter-repo 清除）。
# 引擎运行时会在这两个目录下读写用户导入的卡/预设；测试用合成 fixture 另置，勿放个人数据。
data/characters/
data/presets/
data/third_party/
data/users/*/third_party/

# 遗留根级 RP 文件：新数据根不再生成，但继续忽略已有用户文件
data/items.md
data/world.md
# 封卷记忆 / gating 决策 / session 命名空间 / state 衍生，均 per-user 运行时
data/**/memory/
data/**/gating/
data/**/state/
data/**/sessions/
data/**/history/
data/**/turn_counter*
data/**/*.lock

# AI agent 旁路产物（AtomCode/Claude 等会话元数据），不属本仓
.claude/
.atomcode/
.codex/
.test-data/
.uploads/

# 本地审计/烟测原始输出只作临时诊断；可重复证据由 CI run 与历史归档索引保存
docs/audits/
docs/smoke-evidence/

# PR body 模板（本地起草用，不入库；避免误提交污染仓库根）
.pr-*.md
