# Rust
/target/
**/*.rs.bk
*.pdb

# Cargo workspace — 各成员不再保留独立 lock/target
crates/*/target/
crates/*/Cargo.lock
ui/src-tauri/target/
ui/src-tauri/Cargo.lock

# Node / 前端
ui/node_modules/
ui/dist/
ui/dist-ssr/
ui/.vite/
*.local

# Tauri
ui/src-tauri/gen/schemas/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 环境与密钥
.env
.env.local
.env.*.local

# 运行时数据（core 的样本数据保留入库，但运行产物忽略）
crates/core/data/**/*.log
crates/core/data/sessions/
# 引擎运行时产物（Phase 0 端到端验证生成）：config.json 是 daemon 启动自动写的，
# history/ turn_counter/ quota.json 是会话/封卷/quota 计数器，均不入库。
config.json
data/quota.json
data/characters/*/history/
data/characters/*/memory/turn_counter.txt
